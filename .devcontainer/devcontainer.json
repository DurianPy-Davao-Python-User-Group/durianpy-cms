{
  "name": "DurianPy CMS Dev",
  "dockerComposeFile": "compose.devcontainer.yml",
  "service": "durianpy-cms",
  "workspaceFolder": "/app",
  "features": { "ghcr.io/devcontainers/features/git:1": {} },
  "forwardPorts": [3000, 27017],
  "customizations": {
    "vscode": {
      "extensions": ["mongodb.mongodb-vscode", "dbaeumer.vscode-eslint", "esbenp.prettier-vscode"],
      "settings": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.detectIndentation": false,
        "files.trimTrailingWhitespace": true,
        "json.format.enable": true
      }
    }
  },
  "remoteUser": "node",
  "containerUser": "node",
  "postCreateCommand": "npm run payload migrate",
  "postStartCommand": "npm run dev"
}
